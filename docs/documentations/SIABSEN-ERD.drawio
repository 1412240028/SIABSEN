        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n\n    USERS {\n        BIGINT id PK\n        VARCHAR name\n        VARCHAR email\n        VARCHAR password\n        ENUM role\n        VARCHAR avatar\n        TIMESTAMP created_at\n        TIMESTAMP updated_at\n    }\n\n    MAHASISWA {\n        BIGINT id PK\n        BIGINT user_id FK\n        BIGINT kelas_id FK\n        VARCHAR nim\n        VARCHAR nama\n        VARCHAR jenis_kelamin\n        DATE tanggal_lahir\n        VARCHAR no_hp\n        TEXT alamat\n        YEAR angkatan\n        TIMESTAMP created_at\n        TIMESTAMP updated_at\n        TIMESTAMP deleted_at\n    }\n\n    DOSEN {\n        BIGINT id PK\n        BIGINT user_id FK\n        VARCHAR nidn\n        VARCHAR nama\n        VARCHAR jenis_kelamin\n        VARCHAR no_hp\n        TEXT alamat\n        TIMESTAMP created_at\n        TIMESTAMP updated_at\n        TIMESTAMP deleted_at\n    }\n\n    KELAS {\n        BIGINT id PK\n        VARCHAR nama_kelas\n        YEAR angkatan\n        INTEGER kapasitas\n        BOOLEAN status\n        TIMESTAMP created_at\n        TIMESTAMP updated_at\n        TIMESTAMP deleted_at\n    }\n\n    MATA_KULIAH {\n        BIGINT id PK\n        VARCHAR kode\n        VARCHAR nama\n        INTEGER sks\n        BOOLEAN status\n        TIMESTAMP created_at\n        TIMESTAMP updated_at\n        TIMESTAMP deleted_at\n    }\n\n    JADWAL {\n        BIGINT id PK\n        BIGINT dosen_id FK\n        BIGINT kelas_id FK\n        BIGINT mata_kuliah_id FK\n        ENUM semester\n        VARCHAR tahun_ajaran\n        ENUM hari\n        TIME jam_mulai\n        TIME jam_selesai\n        VARCHAR ruangan\n        BOOLEAN status\n        TIMESTAMP created_at\n        TIMESTAMP updated_at\n        TIMESTAMP deleted_at\n    }\n\n    SESI_PRESENSI {\n        BIGINT id PK\n        BIGINT jadwal_id FK\n        INTEGER pertemuan_ke\n        DATE tanggal\n        VARCHAR token\n        DATETIME opened_at\n        DATETIME expired_at\n        DATETIME closed_at\n        ENUM status\n        TIMESTAMP created_at\n        TIMESTAMP updated_at\n    }\n\n    PRESENSI {\n        BIGINT id PK\n        BIGINT sesi_presensi_id FK\n        BIGINT mahasiswa_id FK\n        ENUM status\n        ENUM metode\n        DATETIME waktu_presensi\n        TEXT catatan\n        TIMESTAMP created_at\n        TIMESTAMP updated_at\n    }\n\n    USERS ||--|| MAHASISWA : memiliki\n    USERS ||--|| DOSEN : memiliki\n\n    KELAS ||--o{ MAHASISWA : berisi\n\n    DOSEN ||--o{ JADWAL : mengajar\n    KELAS ||--o{ JADWAL : memiliki\n    MATA_KULIAH ||--o{ JADWAL : dijadwalkan\n\n    JADWAL ||--o{ SESI_PRESENSI : memiliki\n\n    SESI_PRESENSI ||--o{ PRESENSI : mencatat\n\n    MAHASISWA ||--o{ PRESENSI : melakukan&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="CrSw-MZOJhxLMA7f-NqH-1">
